# MCP Server Environment Variables
# Copy this file to .env and add your API keys

# Brave Search API Key (Required for Brave Search MCP)
# Get from: https://brave.com/search/api/
BRAVE_API_KEY=your_brave_api_key_here

# Firecrawl API Key (Required for Firecrawl MCP)
# Get from: https://firecrawl.dev/
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Apidog Configuration (Optional for API documentation)
# Configure when adding specific API documentation
APIDOG_PROJECT_ID=your_project_id_here

# Anthropic Prompt Caching (for better performance)
ANTHROPIC_CACHE_PROMPT=true
ANTHROPIC_CACHE_TTL=3600

# Existing LifeManager API Keys (if not already set)
# OPENAI_API_KEY=your_openai_key_here
# SUPABASE_URL=your_supabase_url_here
# CLAUDE_API_KEY=your_claude_key_here
EOF < /dev/null